{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "ignore-gtk-theme": true,
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "control-center-layer": "top",
  "layer-shell": true,
  "layer-shell-cover-screen": false,
  "cssPriority": "user",

  "control-center-margin-top": 8,
  "control-center-margin-bottom": 8,
  "control-center-margin-right": 8,
  "control-center-margin-left": 0,

  "notification-2fa-action": true,
  "notification-inline-replies": true,
  "notification-body-image-height": 150,
  "notification-body-image-width": 200,
  "notification-icon-size": 40,

  "timeout": 8,
  "timeout-low": 5,
  "timeout-critical": 0,

  "fit-to-screen": true,
  "relative-timestamps": true,
  "control-center-width": 460,
  "control-center-height": -1,
  "notification-window-width": 420,

  "keyboard-shortcuts": true,
  "notification-grouping": true,
  "image-visibility": "when-available",
  "transition-time": 200,
  "hide-on-clear": false,
  "hide-on-action": true,
  "text-empty": "  Sin notificaciones",
  "script-fail-notify": true,

  "scripts": {
    "pantalla-bloqueo": {
      "exec": "true",
      "summary": ".*Inactividad detectada.*",
      "urgency": "Low"
    },
    "captura-guardada": {
      "exec": "true",
      "app-name": "captura"
    },
    "bateria-critica": {
      "exec": "true",
      "app-name": "Bateria",
      "urgency": "Critical"
    },
    "bateria-alta": {
      "exec": "true",
      "app-name": "BateriaAlta"
    }
  },

  "notification-visibility": {
    "silenciar-discord-juego": {
      "state": "muted",
      "app-name": "discord",
      "urgency": "Low"
    }
  },

  "widgets": [
    "title",
    "dnd",
    "mpris",
    "buttons-grid",
    "notifications"
  ],

  "widget-config": {
    "notifications": {
      "vexpand": true
    },
    "title": {
      "text": "Centro de Control",
      "clear-all-button": true,
      "button-text": "󰃢 Limpiar"
    },
    "dnd": {
      "text": "󰂛 No Molestar"
    },
    "label": {
      "max-lines": 3,
      "text": ""
    },
    "mpris": {
      "blacklist": ["chromium", "firefox"],
      "autohide": true,
      "show-album-art": "always",
      "loop-carousel": true
    },
    "buttons-grid": {
      "buttons-per-row": 4,
      "actions": [
        {
          "label": "󰤨",
          "type": "toggle",
          "active": true,
          "command": "sh -c '[[ $SWAYNC_TOGGLE_STATE == true ]] && nmcli radio wifi on || nmcli radio wifi off'",
          "update-command": "sh -c '[[ $(nmcli radio wifi) == \"enabled\" ]] && echo true || echo false'"
        },
        {
          "label": "󰂯",
          "type": "toggle",
          "active": false,
          "command": "sh -c '[[ $SWAYNC_TOGGLE_STATE == true ]] && bluetoothctl power on || bluetoothctl power off'",
          "update-command": "sh -c '[[ $(bluetoothctl show | grep \"Powered: yes\") ]] && echo true || echo false'"
        },
        {
          "label": "󰕾",
          "type": "toggle",
          "active": false,
          "command": "sh -c '[[ $SWAYNC_TOGGLE_STATE == true ]] && pamixer --mute || pamixer --unmute'",
          "update-command": "sh -c '[[ $(pamixer --get-mute) == \"true\" ]] && echo false || echo true'"
        },
        {
          "label": "󰃠",
          "type": "normal",
          "command": "brightnessctl set 100%"
        },
        {
          "label": "󰒘",
          "type": "normal",
          "command": "~/.config/swaync/scripts/toggle-gamemode.sh"
        },
        {
          "label": "󰏘",
          "type": "normal",
          "command": "hyprpicker -a"
        },
        {
          "label": "󰐪",
          "type": "normal",
          "command": "grimblast copy area"
        },
        {
          "label": "󰤄",
          "type": "normal",
          "command": "systemctl suspend"
        }
      ]
    }
  }
}